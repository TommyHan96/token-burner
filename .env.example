# 选择使用的模型提供商: anthropic, openai, google, cohere, baidu, aliyun, xunfei, zhipu, moonshot
MODEL_PROVIDER=anthropic

# Claude (Anthropic) API配置
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-opus-4-20250514

# OpenAI API配置
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini API配置
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-pro

# Cohere API配置
COHERE_API_KEY=your-cohere-api-key-here
COHERE_MODEL=command

# 百度文心一言 API配置
BAIDU_API_KEY=your-baidu-api-key-here
BAIDU_SECRET_KEY=your-baidu-secret-key-here
BAIDU_MODEL=ERNIE-Bot-4

# 阿里通义千问 API配置
ALIYUN_API_KEY=your-aliyun-api-key-here
ALIYUN_MODEL=qwen-max

# 讯飞星火 API配置
XUNFEI_APP_ID=your-xunfei-app-id-here
XUNFEI_API_KEY=your-xunfei-api-key-here
XUNFEI_API_SECRET=your-xunfei-api-secret-here
XUNFEI_MODEL=spark-3.5

# 智谱AI API配置
ZHIPU_API_KEY=your-zhipu-api-key-here
ZHIPU_MODEL=glm-4

# Moonshot (Kimi) API配置
MOONSHOT_API_KEY=your-moonshot-api-key-here
MOONSHOT_MODEL=moonshot-v1-128k

# 通用配置
MAX_TOKENS=8000
TEMPERATURE=1.0
